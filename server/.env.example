# Server config. Copy to server/.env for local dev.

PORT=4000

# MongoDB connection string. If UNSET, the server uses an in-memory repository
# (great for a quick look; data is NOT persisted across restarts).
# MONGODB_URI=mongodb://localhost:27017/value-chain-mapper

# Secret used to sign session cookies. MUST be a long random string in production.
JWT_SECRET=change-me-in-production

# Active auth provider: "sample" (demo sign-in, no password) or "entra".
AUTH_PROVIDER=sample

# Allowed client origin(s) for CORS when the client runs separately in dev
# (comma-separated). Not needed when the server serves the client (prod).
CLIENT_ORIGIN=http://localhost:5173

# --- Microsoft Entra ID (Azure AD) — for the not-yet-wired `entra` provider ---
# See server/auth/entraProvider.js and SETUP.md. Set AUTH_PROVIDER=entra to use.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:4000/api/auth/callback
